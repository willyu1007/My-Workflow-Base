{
  "name": "@willyu1007/web-workbench",
  "version": "0.6.3",
  "type": "module",
  "description": "Scenario-agnostic web workbench UI kit (Scene paradigms) — contracts + presentational React components.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/willyu1007/My-Workflow-Base.git",
    "directory": "templates/web-workbench"
  },
  "sideEffects": [
    "*.css"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./contracts": {
      "types": "./dist/contracts/index.d.ts",
      "default": "./dist/contracts/index.js"
    },
    "./styles": "./dist/styles/index.css",
    "./styles/*": "./dist/styles/*",
    "./stylelint": "./dist/lint/stylelint.cjs",
    "./eslint": "./dist/lint/eslint.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && pnpm run build:css && pnpm run build:lint",
    "build:css": "mkdir -p dist/styles && cp src/styles/*.css dist/styles/",
    "build:lint": "mkdir -p dist/lint && cp lint/stylelint.cjs lint/eslint.js dist/lint/",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "prepublishOnly": "pnpm run build"
  },
  "peerDependencies": {
    "next": ">=15",
    "react": ">=19",
    "react-dom": ">=19"
  },
  "devDependencies": {
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "next": "^16",
    "react": "^19",
    "react-dom": "^19",
    "typescript": "^5.4.0"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  }
}
